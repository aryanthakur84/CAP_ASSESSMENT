<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin">
        <Title text="Purchase Order Summary" level="H3"/>

        <ObjectStatus
    text="{status}"
    state="{= ${status} === 'Approved' ? 'Success'
           : ${status} === 'Rejected' ? 'Error'
           : ${status} === 'Pending' ? 'Warning'
           : 'None'}"/>

<ProgressIndicator
    percentValue="100"
    displayValue="100%"
    state="{= ${status} === 'Approved' ? 'Success'
           : ${status} === 'Rejected' ? 'Error'
           : ${status} === 'Pending' ? 'Warning'
           : 'None'}"/>
    </VBox>

</core:FragmentDefinition>