{
  "_version": "1.85.0",
  "sap.app": {
    "id": "pomanagement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.26.0",
      "toolsId": "d405140a-94ed-4bd7-955f-f2303cb39801"
    },
    "dataSources": {
      "mainService": {
        "uri": "/purchasing/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
      "crossNavigation": {
    "inbounds": {
      "intent1": {
        "semanticObject": "PurchaseOrders",
        "action": "manage",
        "title": "Manage Purchase Orders",
        "signature": {
          "parameters": {},
          "additionalParameters": "allowed"
        }
      }
    }
  }
  },
  
  "sap.cloud": {
  "public": true,
  "service": "pomanagement"
},
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.149.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "pomanagement.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PurchaseOrdersList",
          "target": "PurchaseOrdersList"
        },
        {
          "pattern": "PurchaseOrders({key}):?query:",
          "name": "PurchaseOrdersObjectPage",
          "target": "PurchaseOrdersObjectPage"
        },
        {
          "pattern": "PurchaseOrders({key})/items({key2}):?query:",
          "name": "PurchaseOrderItemsObjectPage",
          "target": "PurchaseOrderItemsObjectPage"
        }
      ],
      "targets": {
        "PurchaseOrdersList": {
          "type": "Component",
          "id": "PurchaseOrdersList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PurchaseOrders",
              "variantManagement": "Page",
              "navigation": {
                "PurchaseOrders": {
                  "detail": {
                    "route": "PurchaseOrdersObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "PurchaseOrdersObjectPage": {
          "type": "Component",
          "id": "PurchaseOrdersObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PurchaseOrders",
              "navigation": {
                "items": {
                  "detail": {
                    "route": "PurchaseOrderItemsObjectPage"
                  }
                }
              },
              "content": {
                "body": {
                  "sections": {
                    "POStatusSection": {
                      "template": "pomanagement.ext.POStatusSection",
                      "title": "PO Status Progress",
                      "position": {
                        "placement": "After",
                        "anchor": "Items"
                      }
                    }
                  }
                },
                "header": {
                  "anchorBarVisible": true
                }
              }
            }
          }
        },
        "PurchaseOrderItemsObjectPage": {
          "type": "Component",
          "id": "PurchaseOrderItemsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PurchaseOrders/items"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}