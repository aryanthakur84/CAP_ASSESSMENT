#################################################
# TEST 5: View Orders
#################################################

GET http://localhost:4004/odata/v4/sales/SalesOrders

###

#################################################
# GET ORDERS WITH ITEMS
#################################################

GET http://localhost:4004/odata/v4/sales/SalesOrders?$expand=items

###

