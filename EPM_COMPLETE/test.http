#################################################
# TEST 4: Valid Order (SUCCESS)
#################################################

POST http://localhost:4004/odata/v4/sales/SalesOrders
Content-Type: application/json

{
  "customer_ID": "CUS1",
  "orderDate": "2026-08-15",
  "currency": "INR",
  "items": [
    {
      "product_ID": "PROD1",
      "quantity": 1,
      "unitPrice": 50
    },
    {
      "product_ID": "PROD5",
      "quantity": 1,
      "unitPrice": 29.99
    }
  ]
}

